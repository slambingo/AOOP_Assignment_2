<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:LibraryApp.ViewModels"
             xmlns:views="using:LibraryApp.Views"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="LibraryApp.Views.TabControlWindow"
             x:DataType="vm:TabControlWindowViewModel">


  <TabControl Margin="5">
    <TabItem Header="Catalog">
      <ContentControl Content="{Binding Tab1Window}"/>
    </TabItem>
    <TabItem Header="Profile">
      <ContentControl Content="{Binding Tab2Window}"/>
    </TabItem>
  </TabControl>
</UserControl>
