<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:LibraryApp.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="LibraryApp.Views.ProfileWindow"
             x:DataType="vm:ProfileWindowViewModel">

  <StackPanel Margin="20" VerticalAlignment="Center">
      <TextBlock Text="{Binding Username}" HorizontalAlignment="Center"/>
      <TextBlock Text="{Binding Role}" HorizontalAlignment="Center"/>
      
      <Button Margin="0 5" Width= "100" HorizontalAlignment="Center" Content="Log Out" HorizontalContentAlignment="Center" Command="{Binding LogOut}"/>
  </StackPanel> 
</UserControl>
