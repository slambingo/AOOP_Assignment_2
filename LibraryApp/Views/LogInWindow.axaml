<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:LibraryApp.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="LibraryApp.Views.LogInWindow"
             x:DataType="vm:LogInWindowViewModel">



    <StackPanel Margin="20" VerticalAlignment="Center">
        <TextBlock Text="Welcome, Please Log In" HorizontalAlignment="Center"/>
        
    
        <TextBox Margin="0 5" Width="200" Watermark="Username" Text="{Binding Username}" HorizontalAlignment="Center"/>
        <TextBox Margin="0 5" Width="200" PasswordChar="*" Watermark="Password" Text="{Binding Password}" HorizontalAlignment="Center"/>
        <Button Margin="0 5" Width= "100" HorizontalAlignment="Center" Content="Log In" HorizontalContentAlignment="Center" Command="{Binding LogIn}"/>


    </StackPanel>



</UserControl>
